# ═══════════════════════════════════════════════════════════════════
# Jenkins JCasC Secrets — Required Environment Variables
# ═══════════════════════════════════════════════════════════════════
# Copy to .env and fill in real values. Only secrets go here —
# all non-secret config is hardcoded directly in jenkins.yml.
#
# Load via: systemd EnvironmentFile, Docker --env-file, or K8s Secret.
# ═══════════════════════════════════════════════════════════════════

# ── Jenkins Admin ──
JENKINS_ADMIN_PASSWORD=changeme

# ── OCIR (Oracle Cloud Container Registry) ──
OCIR_USERNAME=tenancy/user@example.com
OCIR_PASSWORD=auth-token-here

# ── GitHub ──
GIT_USERNAME=jenkins
GIT_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# ── Notifications (optional — leave blank to skip) ──
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ
TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/XXX

# ── SonarQube (optional) ──
SONAR_TOKEN=sqp_xxxxxxxxxxxxxxxxxxxx
